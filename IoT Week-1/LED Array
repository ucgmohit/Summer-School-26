int led[]={3,5,6,9,10};
int led_num=5;
void setup()
{
 for(int i=0;i<led_num;i++)
 {
   pinMode(led[i],OUTPUT);
 }
}

void loop()
{
  for(int i=0;i<led_num;i++)
  {
    for(int bright=0;bright<=255;bright++)
    {
      analogWrite(led[i],bright);
      delay(1);
    }
    
    for(int bright=255;bright>=0;bright--)
    {
      analogWrite(led[i],bright);
      delay(1);
    }
  }
    
}
