Description:
LED Blink using potentiometer to control blink speed.
Displays blink count on the Serial Monitor.
*/
int count = 0;


void setup() {
  pinMode(13, OUTPUT);
  Serial.begin(9600);
}

void loop() {

  int sensor = analogRead(A0);

  int speed = map(sensor, 0, 1023, 100, 1000);

  digitalWrite(13, HIGH);
  delay(speed);
  digitalWrite(13, LOW);
  delay(speed);

  count++;

  Serial.print("Blink count: ");
  Serial.println(count);
}
